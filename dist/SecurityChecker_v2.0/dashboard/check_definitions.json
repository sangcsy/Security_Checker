{
  "metadata": {
    "version": "1.0",
    "based_on": "KISA 기술적 취약점 분석·평가 방법 상세가이드",
    "target_os": "Windows",
    "description": "Windows 보안 구성 검사 항목 정의"
  },
  "checks": [
    {
      "item_code": "W-01",
      "category": "계정 관리",
      "check_title": "Administrator 계정 이름 변경",
      "description": "기본 Administrator 계정 이름 사용 여부 확인",
      "check_type": "registry",
      "severity": "상",
      "check_method": {
        "type": "powershell",
        "command": "Get-LocalUser | Where-Object {$_.SID -like '*-500'} | Select-Object -ExpandProperty Name"
      },
      "expected_state": "Administrator가 아닌 다른 이름으로 변경됨",
      "compliance_criteria": {
        "good": "Administrator 계정 이름이 변경되어 있음",
        "bad": "기본 Administrator 이름을 사용 중"
      },
      "operational_meaning": "기본 관리자 계정 이름을 변경하면 자동화된 공격 도구로부터 계정을 보호할 수 있습니다."
    },
    {
      "item_code": "W-02",
      "category": "계정 관리",
      "check_title": "Guest 계정 비활성화",
      "description": "Guest 계정 비활성화 여부 확인",
      "check_type": "account",
      "severity": "상",
      "check_method": {
        "type": "powershell",
        "command": "Get-LocalUser -Name 'Guest' | Select-Object -ExpandProperty Enabled"
      },
      "expected_state": "Guest 계정이 비활성화되어 있음",
      "compliance_criteria": {
        "good": "Guest 계정이 비활성화됨",
        "bad": "Guest 계정이 활성화됨"
      },
      "operational_meaning": "Guest 계정을 비활성화하여 인증되지 않은 사용자의 시스템 접근을 차단합니다."
    },
    {
      "item_code": "W-03",
      "category": "계정 관리",
      "check_title": "불필요한 계정 존재 여부",
      "description": "사용하지 않는 계정 존재 여부 확인",
      "check_type": "account",
      "severity": "중",
      "check_method": {
        "type": "powershell",
        "command": "Get-LocalUser | Where-Object {$_.Enabled -eq $true} | Select-Object Name, LastLogon, Enabled | ConvertTo-Json -Compress"
      },
      "expected_state": "불필요한 계정이 존재하지 않음",
      "compliance_criteria": {
        "good": "활성화된 모든 계정이 업무상 필요한 계정임",
        "bad": "사용하지 않는 계정이 활성화되어 있음"
      },
      "operational_meaning": "불필요한 계정을 제거하여 공격 표면을 줄이고 계정 관리를 용이하게 합니다."
    },
    {
      "item_code": "W-04",
      "category": "암호 정책",
      "check_title": "암호 복잡성 설정",
